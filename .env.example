# CarbonMint frontend environment variables
# Copy this file to .env and adjust as needed. The demo runs fully on mock
# data, so none of these are required for local development.

# Stellar network the (mock) wallet reports as connected.
VITE_STELLAR_NETWORK=TESTNET

# Soroban RPC endpoint (unused by the mock services; placeholder for real wiring).
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Contract id of the CARBON token / marketplace contract (placeholder).
VITE_CARBON_CONTRACT_ID=

# Default settlement asset code shown in the UI.
VITE_SETTLEMENT_ASSET=USDC
